class Solution {
public:
    bool uniformArray(vector<int>& nums1) {
        int mini=INT_MAX;
        int odd=0,even=0;
        for(int i=0; i<nums1.size(); i++){
            if(nums1[i]%2==0){
                even++;
            }else{
                odd++;
                mini = min(nums1[i],mini);
            }
        }
        if(odd==0 || even ==0 ){
            return true;
        }
        for(int i=0; i<nums1.size(); i++){
            if(nums1[i] %2 == 0){
                if(nums1[i] <= mini){
                    return false;
                }
            }
        }
        return true;
    }
};
