Input: s = "idea"
Output: "id"
Explanation:
Removing "idea", we obtain the string "id"
#code:
class Solution {
public:
    bool isVowel(char c) {
  
    if (c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u' ||
        c == 'A' || c == 'E' || c == 'I' || c == 'O' || c == 'U') {
        return true;
    } else {
        return false;
    }
}
    string trimTrailingVowels(string s) {
        int n = s.size();
        int i;
        for(i=n-1; i>=0; i--){
            if(!isVowel(s[i])){
                break;
            }
        }
        return s.substr(0,i+1);
    }
};
