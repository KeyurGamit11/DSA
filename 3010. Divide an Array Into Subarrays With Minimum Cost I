Input: nums = [1,2,3,12]
Output: 6
Explanation: The best possible way to form 3 subarrays is: [1], [2], and [3,12] at a total cost of 1 + 2 + 3 = 6.
The other possible ways to form 3 subarrays are:
- [1], [2,3], and [12] at a total cost of 1 + 2 + 12 = 15.
- [1,2], [3], and [12] at a total cost of 1 + 3 + 12 = 16.
#code:
class Solution {
public:
    int minimumCost(vector<int>& nums) {
        
        //we have to choose first el and after that choose two mini from 1 to n range

        int sec_mini=INT_MAX,sec_ind=-1;
        int third_mini =INT_MAX;
        for(int i=1; i<nums.size(); i++){
            if(nums[i] < sec_mini){
                sec_ind = i;
                sec_mini = nums[i];
            }
        }
        for(int i=1; i<nums.size(); i++){
            if(nums[i] <= third_mini &&  i != sec_ind){ 
                third_mini = nums[i];
            }
        }
        return nums[0]+sec_mini+third_mini;
    }
};
