Input: nums1 = [2,3]
Output: true
Explanation:
Choose nums2[0] = nums1[0] - nums1[1] = 2 - 3 = -1.
Choose nums2[1] = nums1[1] = 3.
nums2 = [-1, 3], and both elements are odd. Thus, the answer is true‚Äã‚Äã‚Äã‚Äã‚Äã‚Äã‚Äã.
#code:
#here we dont need to do anything we just return true because there is no tc that can be false , we can make every arr into full odd or even with these ops 
class Solution {
public:
    bool uniformArray(vector<int>& nums1) {
        int odd=0,even=0;
        for(int i=0; i<nums1.size(); i++){
            if(nums1[i]%2==0){
                even++;
            }else{
                odd++;
            }
        }
        if(even==0 || odd==0) {
            return true;
        }
        return true;
        
    }
};
