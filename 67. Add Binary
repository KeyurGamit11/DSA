Input: a = "11", b = "1"
Output: "100"
#code:
class Solution {
public:
    string addBinary(string a, string b) {
        int n = a.size()-1;
        int m = b.size()-1;
        int carry=0;
        int sum=0;
        string ans="";
        while(m >=0 || n >=0){
            sum = carry;
            if(m >=0){
                sum += b[m]-'0';
                m--;
            }
            if(n >=0){
                sum += a[n]-'0';
                n--;
            }
            ans.push_back((sum%2==0) ? '0':'1');
            carry = (sum>1) ? 1:0;
        }
        if(carry){
            ans.push_back('1');
        }
        reverse(ans.begin(),ans.end());
        return ans;
    }
};
